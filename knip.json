{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "next.config.mjs",
    "open-next.config.ts",
    "src/app/**/*.{ts,tsx}",
    "src/**/*.test.ts",
    "src/**/*.unit.test.ts",
    "src/**/*.integration.test.ts",
    "src/**/*.contract.test.ts",
    "src/**/*.e2e.test.ts"
  ],
  "ignore": [
    ".dependency-graph/**",
    ".next/**",
    ".open-next/**",
    ".vercel/**",
    "dist/**"
  ],
  "ignoreBinaries": [
    "eslint",
    "next",
    "opennextjs-cloudflare",
    "wrangler"
  ],
  "ignoreDependencies": [
    "madge",
    "sharp",
    "@types/node",
    "@types/react",
    "@types/react-dom"
  ],
  "project": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.ts",
    "*.tsx"
  ]
}
